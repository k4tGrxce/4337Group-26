<Window x:Class="Group4337._4337_Соловьев"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Group4337"
        mc:Ignorable="d"
        Title="_4337_Соловьев" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" Margin="10">
            <Button Margin="0,0,10,0" Content="Импорт данных" Click="Import_Click" />
            <Button Margin="0,0,10,0" Content="Экспорт в Excel" Click="Export_Click"/>
            <Button Margin="0,0,10,0" Content="Импорт JSON данных" Click="Import_Json_Click"/>
            <Button Margin="0,0,10,0" Content="Экспорт в Word" Click="Export_Word_Click"/>
        </StackPanel>
        <TextBlock Text="Соловьёв Станислав, 18 "
               FontSize="20"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" Grid.Column="0"/>
    </Grid>
</Window>
